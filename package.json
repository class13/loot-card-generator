{
  "name": "loot-card-generator",
  "version": "1.0.0",
  "description": "Generate print-ready D&D loot card PDFs from YAML files",
  "type": "module",
  "bin": {
    "loot-cards": "./dist/bin/loot-cards.js",
    "loot-card-icons": "./dist/bin/loot-card-icons.js",
    "loot-card-prompts": "./dist/bin/loot-card-prompts.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && node dist/bin/loot-cards.js",
    "icons": "npm run build && node dist/bin/loot-card-icons.js",
    "prompts": "npm run build && node dist/bin/loot-card-prompts.js"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "puppeteer": "^22.0.0",
    "quicktype": "^23.2.6",
    "yamljs": "^0.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2"
  }
}
